# Copy this file to .env and fill in all values before running docker compose.
# Never commit .env to version control.

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASS=
POSTGRES_DB=log-analyzer
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_USER=
RABBITMQ_PASS=
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Redis
REDIS_PORT=6379
REDIS_PASS=               # required by compose-deploy.yml; not used by compose.yml

# MinIO
MINIO_USER=
MINIO_PASS=
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=models
MINIO_SECURE=false

# Application ports
APP_PORT=8080
DETECTION_PORT=8000
SIMULATION_PORT=8001
REACTION_PORT=8082
DASHBOARD_PORT=8083
FRONTEND_PORT=443
FRONTEND_HTTP_PORT=80

# Dashboard
CORS_ORIGINS=http://localhost:3000

# Simulation service
ADMIN_API_KEY=

# Reaction service — alert channels
# ALERT_PROVIDER selects the active channel: smtp | resend | discord (default: smtp)
ALERT_PROVIDER=smtp

# SMTP (used when ALERT_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_MAIL_FROM=
ALERT_MAIL_TO=

# Resend email API (used when ALERT_PROVIDER=resend)
RESEND_API_KEY=

# Discord webhook (used when ALERT_PROVIDER=discord)
DISCORD_WEBHOOK_URL=

# Public domain (deploy mode only). dashboard-fe mounts the Let's Encrypt
# certificate from /etc/letsencrypt/live/${DOMAIN}/{fullchain,privkey}.pem
DOMAIN=