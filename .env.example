# Copy this file to .env and fill in all values before running docker compose.
# Never commit .env to version control.

# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=log-analyzer
POSTGRES_PORT=5432

# RabbitMQ
# compose.yml uses RABBITMQ_USERNAME / RABBITMQ_PASSWORD (Spring naming)
# compose-deploy.yml uses RABBITMQ_USER / RABBITMQ_PASS (shorter aliases)
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
RABBITMQ_USER=
RABBITMQ_PASS=
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Redis
REDIS_PORT=6379

# MinIO
MINIO_USER=
MINIO_PASSWORD=
MINIO_PASS=
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=models
MINIO_SECURE=false

# Application ports
APP_PORT=8080
DETECTION_PORT=8000
