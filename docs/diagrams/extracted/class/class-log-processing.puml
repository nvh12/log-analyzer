@startuml class-log-processing
hide circle
skinparam classAttributeIconSize 0

class LogProcessingService {
    - {static} CLF_PATTERN: Pattern
    - {static} CLF_DATE: DateTimeFormatter
    - objectMapper: ObjectMapper
    - validation: ValidationLimits
    
    + LogProcessingService(objectMapper: ObjectMapper, validation: ValidationLimits)
    + process(rawLog: RawLog): ProcessingResult
    - parseHttp(rawLog: RawLog): NormalizedLog
    - parseFlow(rawLog: RawLog): NormalizedFlowRecord
    - toDouble(val: Object): double
    - sanitize(val: Object): double
}

@enduml
